        "type": "org.apache.nifi.processors.cdc.postgresql.CaptureChangePostgreSQL",
        "bundle": { "group": "org.apache.nifi", "artifact": "nifi-cdc-postgresql-nar", "version": "2.0.0" },
        "position": { "x": 100.0, "y": 300.0 },
        "properties": {
          "PostgreSQL Connection Host": "#{postgres_host}",
          "PostgreSQL Connection Port": "#{postgres_port}",
          "PostgreSQL DB Name": "#{postgres_database}",
          "PostgreSQL Username": "#{postgres_username}",
          "PostgreSQL Password": "#{postgres_password}",
          "Replication Slot Name": "#{postgres_slot_name}",
          "Publication Name": "#{postgres_publication}",
          "Output Format": "JSON",
          "Include Begin Transaction": "false",
          "Include Commit Transaction": "false",
          "SSL Mode": "require",
          "Status Interval": "10 secs",
          "Max Flush Size": "10000"
        },
        "propertyDescriptors": {},
        "style": {},
        "schedulingStrategy": "TIMER_DRIVEN",
        "schedulingPeriod": "1 sec",
        "executionNode": "PRIMARY",
        "penaltyDuration": "30 sec",
        "yieldDuration": "3 sec",
        "bulletinLevel": "WARN",
        "runDurationMillis": 0,
        "concurrentlySchedulableTaskCount": 1,
        "autoTerminatedRelationships": ["failure"],
        "retriedRelationships": [],
        "scheduledState": "ENABLED",
        "retryCount": 0,
