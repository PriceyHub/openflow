        "name": "RouteOnAttribute - Table Router",
        "type": "org.apache.nifi.processors.standard.RouteOnAttribute",
        "bundle": { "group": "org.apache.nifi", "artifact": "nifi-standard-nar", "version": "2.0.0" },
        "position": { "x": 400.0, "y": 300.0 },
        "properties": {
          "Routing Strategy": "Route to 'matched' if all match",
          "customers": "${cdc.table:equals('customers')}",
          "orders": "${cdc.table:equals('orders')}"
        },
        "propertyDescriptors": {},
        "style": {},
        "schedulingStrategy": "TIMER_DRIVEN",
        "schedulingPeriod": "0 sec",
        "executionNode": "ALL",
        "penaltyDuration": "30 sec",
        "yieldDuration": "1 sec",
        "bulletinLevel": "WARN",
        "runDurationMillis": 0,
        "concurrentlySchedulableTaskCount": 4,
        "autoTerminatedRelationships": ["unmatched"],
        "retriedRelationships": [],
        "scheduledState": "ENABLED",
        "retryCount": 0,
        "backoffMechanism": "PENALIZE_FLOWFILE",
        "maxBackoffPeriod": "10 mins"
      },
      {
        "componentType": "PROCESSOR",
        "identifier": "proc-cdc-update-attr",
        "name": "UpdateAttribute - Add CDC Metadata",
        "type": "org.apache.nifi.processors.attributes.UpdateAttribute",
        "bundle": { "group": "org.apache.nifi", "artifact": "nifi-update-attribute-nar", "version": "2.0.0" },
        "position": { "x": 700.0, "y": 300.0 },
        "properties": {
          "cdc.loaded_at": "${now():toNumber()}",
          "s3.prefix": "staged/postgres_cdc/${cdc.table}/${now():format('yyyy/MM/dd')}",
          "target.table.raw": "PG_${cdc.table:toUpper()}_RAW"
        },
        "propertyDescriptors": {},
        "style": {},
        "schedulingStrategy": "TIMER_DRIVEN",
        "schedulingPeriod": "0 sec",
        "executionNode": "ALL",
        "penaltyDuration": "30 sec",
        "yieldDuration": "1 sec",
        "bulletinLevel": "WARN",
        "runDurationMillis": 0,
        "concurrentlySchedulableTaskCount": 4,
        "autoTerminatedRelationships": [],
        "retriedRelationships": [],
        "scheduledState": "ENABLED",
        "retryCount": 0,
        "backoffMechanism": "PENALIZE_FLOWFILE",
        "maxBackoffPeriod": "10 mins"
      },
      {
        "componentType": "PROCESSOR",
        "identifier": "proc-cdc-convert",
        "name": "ConvertRecord - CDC JSON normalise",
        "type": "org.apache.nifi.processors.standard.ConvertRecord",
        "bundle": { "group": "org.apache.nifi", "artifact": "nifi-standard-nar", "version": "2.0.0" },
        "position": { "x": 1000.0, "y": 300.0 },
        "properties": {
          "record-reader": "cs-cdc-json-reader",
          "record-writer": "cs-cdc-json-writer"
        },
        "propertyDescriptors": {},
        "style": {},
        "schedulingStrategy": "TIMER_DRIVEN",
        "schedulingPeriod": "0 sec",
        "executionNode": "ALL",
        "penaltyDuration": "30 sec",
        "yieldDuration": "1 sec",
        "bulletinLevel": "WARN",
        "runDurationMillis": 0,
        "concurrentlySchedulableTaskCount": 4,
        "autoTerminatedRelationships": ["failure"],
        "retriedRelationships": [],
        "scheduledState": "ENABLED",
        "retryCount": 0,
        "backoffMechanism": "PENALIZE_FLOWFILE",
        "maxBackoffPeriod": "10 mins"
      },
      {
        "componentType": "PROCESSOR",
        "identifier": "proc-cdc-merge",
        "name": "MergeRecord - CDC Batch",
        "type": "org.apache.nifi.processors.standard.MergeRecord",
        "bundle": { "group": "org.apache.nifi", "artifact": "nifi-standard-nar", "version": "2.0.0" },
        "position": { "x": 1300.0, "y": 300.0 },
        "properties": {
          "record-reader": "cs-cdc-json-reader",
          "record-writer": "cs-cdc-json-writer",
          "merge-strategy": "Bin-Packing Algorithm",
          "Minimum Number of Records": "100",
          "Maximum Number of Records": "10000",
          "Max Bin Age": "30 sec",
          "Maximum Number of Bins": "10",
          "Merge Criterion": "${cdc.table}"
        },
        "propertyDescriptors": {},
        "style": {},
        "schedulingStrategy": "TIMER_DRIVEN",
        "schedulingPeriod": "0 sec",
        "executionNode": "ALL",
        "penaltyDuration": "30 sec",
        "yieldDuration": "1 sec",
        "bulletinLevel": "WARN",
        "runDurationMillis": 0,
        "concurrentlySchedulableTaskCount": 1,
        "autoTerminatedRelationships": ["original", "failure"],
        "retriedRelationships": [],
        "scheduledState": "ENABLED",
        "retryCount": 0,
        "backoffMechanism": "PENALIZE_FLOWFILE",
        "maxBackoffPeriod": "10 mins"
      },
      {
        "componentType": "PROCESSOR",
        "identifier": "proc-cdc-s3",
        "name": "PutS3Object - CDC Stage",
        "type": "org.apache.nifi.processors.aws.s3.PutS3Object",
        "bundle": { "group": "org.apache.nifi", "artifact": "nifi-aws-nar", "version": "2.0.0" },
        "position": { "x": 1600.0, "y": 300.0 },
        "properties": {
          "Bucket": "#{s3_staging_bucket}",
          "Object Key": "${s3.prefix}/${uuid()}.json",
          "Region": "#{s3_region}",
          "Use Path Style Access": "false",
          "Server Side Encryption": "AES256",
          "Storage Class": "STANDARD"
        },
        "propertyDescriptors": {},
        "style": {},
        "schedulingStrategy": "TIMER_DRIVEN",
        "schedulingPeriod": "0 sec",
        "executionNode": "ALL",
        "penaltyDuration": "30 sec",
        "yieldDuration": "1 sec",
        "bulletinLevel": "WARN",
        "runDurationMillis": 0,
        "concurrentlySchedulableTaskCount": 4,
        "autoTerminatedRelationships": ["failure"],
        "retriedRelationships": [],
        "scheduledState": "ENABLED",
        "retryCount": 3,
        "backoffMechanism": "PENALIZE_FLOWFILE",
        "maxBackoffPeriod": "10 mins"
      },
      {
        "componentType": "PROCESSOR",
        "identifier": "proc-cdc-copy-raw",
        "name": "ExecuteSQL - COPY INTO RAW",
        "type": "org.apache.nifi.processors.standard.ExecuteSQL",
        "bundle": { "group": "org.apache.nifi", "artifact": "nifi-standard-nar", "version": "2.0.0" },
        "position": { "x": 1900.0, "y": 300.0 },
        "properties": {
          "Database Connection Pooling Service": "cs-cdc-dbcp-snowflake",
          "SQL select query": "COPY INTO #{snowflake_database}.RAW.${target.table.raw} (_raw_json, _cdc_operation, _cdc_timestamp, _source_file, _batch_id) FROM (SELECT $1, $1:operation::VARCHAR, $1:transaction_timestamp::TIMESTAMP_NTZ, METADATA$FILENAME, '${s3.key}' FROM @#{snowflake_database}.RAW.OPENFLOW_S3_STAGE/${s3.prefix}/) FILE_FORMAT=(TYPE=JSON STRIP_OUTER_ARRAY=TRUE) ON_ERROR='CONTINUE' PURGE=FALSE",
          "Max Wait Time": "0 millis",
          "Output Batch Size": "0",
          "Fetch Size": "0",
          "Max Rows Per Flow File": "0"
        },
        "propertyDescriptors": {},
        "style": {},
        "schedulingStrategy": "TIMER_DRIVEN",
        "schedulingPeriod": "0 sec",
        "executionNode": "ALL",
        "penaltyDuration": "30 sec",
        "yieldDuration": "1 sec",
        "bulletinLevel": "WARN",
        "runDurationMillis": 0,
        "concurrentlySchedulableTaskCount": 1,
        "autoTerminatedRelationships": ["failure"],
        "retriedRelationships": [],
        "scheduledState": "ENABLED",
        "retryCount": 3,
        "backoffMechanism": "PENALIZE_FLOWFILE",
        "maxBackoffPeriod": "10 mins"
      },
      {
        "componentType": "PROCESSOR",
        "identifier": "proc-cdc-merge-upsert",
        "name": "ExecuteSQL - MERGE INTO Target Table",
        "type": "org.apache.nifi.processors.standard.ExecuteSQL",
        "bundle": { "group": "org.apache.nifi", "artifact": "nifi-standard-nar", "version": "2.0.0" },
        "position": { "x": 2200.0, "y": 300.0 },
        "properties": {
          "Database Connection Pooling Service": "cs-cdc-dbcp-snowflake",
          "SQL select query": "CALL #{snowflake_database}.POSTGRES_CDC.MERGE_CDC_BATCH('${cdc.table}', '${cdc.loaded_at}')",
          "Max Wait Time": "0 millis",
          "Output Batch Size": "0",
          "Fetch Size": "0",
          "Max Rows Per Flow File": "0"
        },
        "propertyDescriptors": {},
        "style": {},
        "schedulingStrategy": "TIMER_DRIVEN",
        "schedulingPeriod": "0 sec",
        "executionNode": "ALL",
        "penaltyDuration": "30 sec",
        "yieldDuration": "1 sec",
        "bulletinLevel": "WARN",
        "runDurationMillis": 0,
        "concurrentlySchedulableTaskCount": 1,
        "autoTerminatedRelationships": ["success", "failure"],
        "retriedRelationships": [],
        "scheduledState": "ENABLED",
        "retryCount": 3,
        "backoffMechanism": "PENALIZE_FLOWFILE",
        "maxBackoffPeriod": "10 mins"
      }
